{% comment %}
  Manual Instagram-style gallery. Originally wired to the third-party Foursixty
  widget (auto-pulled real Instagram posts via an external account); replaced
  with merchant-uploaded blocks (image or video + link) per the site owner's
  choice, since the third-party service needs a separate paid signup — this
  needs zero external accounts and updates directly through the Theme Editor.
{% endcomment %}
<div
  id="shopify-section-{{ section.id }}"
  class="foursixty{% if section.settings.font_override != 'inherit' %} foursixty--font-{{ section.settings.font_override }}{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="foursixty"
>
  {%- if section.settings.title != blank -%}
    <h2 class="foursixty__title page-width">{{ section.settings.title }}</h2>
  {%- endif -%}

  <div
    class="foursixty__grid page-width"
    style="--columns-desktop: {{ section.settings.columns_desktop }}; --columns-mobile: {{ section.settings.columns_mobile }}; --foursixty-gap: {{ section.settings.tile_gap }}px; --foursixty-radius: {{ section.settings.tile_radius }}px;"
  >
    {%- for block in section.blocks -%}
      {%- liquid
        assign tile_tag = 'div'
        if block.settings.link != blank
          assign tile_tag = 'a'
        endif
      -%}
      <{{ tile_tag }}
        {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
        class="foursixty__tile{% if block.settings.link != blank %} foursixty__tile--linked{% endif %}{% if block.settings.featured %} foursixty__tile--featured{% endif %}"
        {{ block.shopify_attributes }}
      >
        <div class="foursixty__media">
          {%- if block.settings.video != blank -%}
            {{ block.settings.video | video_tag: image_size: '600x', autoplay: true, loop: true, muted: true, controls: false, class: 'foursixty__image' }}
          {%- elsif block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 600 | image_tag: widths: '300,450,600', alt: block.settings.alt, class: 'foursixty__image', loading: 'lazy' }}
          {%- endif -%}
        </div>
        <span class="foursixty__overlay">{%- render 'icon', name: 'instagram', icon_size: 28 -%}</span>
      </{{ tile_tag }}>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .foursixty {
    padding-block: var(--section-spacing);
  }

  .foursixty__title {
    text-align: center;
    text-transform: uppercase;
    color: rgb(var(--color-accent));
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    margin-bottom: 1.5rem;
  }

  .foursixty__grid {
    display: grid;
    grid-template-columns: repeat(var(--columns-mobile, 3), 1fr);
    gap: var(--foursixty-gap, 8px);
  }

  .foursixty__tile {
    position: relative;
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: var(--foursixty-radius, 12px);
    background: rgb(var(--color-background-alt));
  }

  .foursixty__tile--featured {
    grid-column: span 2;
    grid-row: span 2;
  }

  .foursixty__tile--linked {
    cursor: pointer;
  }

  .foursixty__media,
  .foursixty__image {
    width: 100%;
    height: 100%;
  }

  .foursixty__image {
    display: block;
    object-fit: cover;
  }

  .foursixty__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    background-color: rgba(0, 0, 0, .25);
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .foursixty__tile:hover .foursixty__overlay,
  .foursixty__tile:focus-visible .foursixty__overlay {
    opacity: 1;
  }

  @media screen and (min-width: 45em) {
    .foursixty__grid {
      grid-template-columns: repeat(var(--columns-desktop, 7), 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.foursixty.name",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "SHOP OUR IG",
      "label": "t:sections.foursixty.title.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 4,
      "max": 8,
      "step": 1,
      "default": 7,
      "label": "t:sections.foursixty.columns_desktop.label"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "t:sections.foursixty.columns_mobile.label"
    },
    {
      "type": "range",
      "id": "tile_gap",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8,
      "label": "t:sections.foursixty.tile_gap.label"
    },
    {
      "type": "range",
      "id": "tile_radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12,
      "label": "t:sections.foursixty.tile_radius.label"
    },
    {
      "type": "select",
      "id": "font_override",
      "options": [
        { "value": "inherit", "label": "t:sections.common.font.inherit" },
        { "value": "heading", "label": "t:sections.common.font.heading" },
        { "value": "body", "label": "t:sections.common.font.body" },
        { "value": "accent", "label": "t:sections.common.font.accent" }
      ],
      "default": "inherit",
      "label": "t:sections.common.font.label"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "t:sections.foursixty.blocks.post.name",
      "settings": [
        {
          "type": "checkbox",
          "id": "featured",
          "default": false,
          "label": "t:sections.foursixty.blocks.post.featured.label",
          "info": "t:sections.foursixty.blocks.post.featured.info"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.foursixty.blocks.post.image.label"
        },
        {
          "type": "video",
          "id": "video",
          "label": "t:sections.foursixty.blocks.post.video.label",
          "info": "t:sections.foursixty.blocks.post.video.info"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "t:sections.foursixty.blocks.post.alt.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.foursixty.blocks.post.link.label",
          "info": "t:sections.foursixty.blocks.post.link.info"
        }
      ]
    }
  ],
  "max_blocks": 21,
  "presets": [
    {
      "name": "t:sections.foursixty.name",
      "blocks": [
        { "type": "post", "settings": { "featured": true } },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" }
      ]
    }
  ]
}
{% endschema %}
