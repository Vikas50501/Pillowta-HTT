{% comment %}
  Maps to: source site's "shop by category" tiles — on the real site this is split
  across 3 separate sections (2 desktop halves + 1 combined mobile version) purely
  because the hover-video/gif crossfade markup was only rendered for desktop;
  rebuilt here as ONE responsive section (blocks = tiles) with hover media handled
  by a plain CSS media query, since Shopify sections already reflow per breakpoint
  without needing a duplicate instance. Each tile: static image, optional hover
  video/gif crossfade, title, link — matches source tiles: lips, fragrance (gif),
  face, blush, Lip Care (gif), eyes.
{% endcomment %}
<div
  id="shopify-section-{{ section.id }}"
  class="multicolumn{% if section.settings.font_override != 'inherit' %} multicolumn--font-{{ section.settings.font_override }}{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="multicolumn"
>
  {%- if section.settings.title != blank -%}
    <h2 class="multicolumn__title page-width">{{ section.settings.title }}</h2>
  {%- endif -%}

  <div
    class="multicolumn__grid page-width"
    style="
      --columns-desktop: {{ section.settings.columns_desktop }};
      --columns-mobile: {{ section.settings.columns_mobile }};
      --multicolumn-gap: {{ section.settings.tile_gap }}px;
      --multicolumn-radius: {{ section.settings.tile_radius }}px;
      --multicolumn-title-color: {{ section.settings.title_color }};
      --multicolumn-title-size: {{ section.settings.title_font_size }}px;
      --multicolumn-title-transform: {{ section.settings.title_text_transform }};
      --multicolumn-overlay-color: {{ section.settings.overlay_color }};
      --multicolumn-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    "
  >
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link }}" class="multicolumn__tile multicolumn__tile--title-{{ section.settings.title_position }}" {{ block.shopify_attributes }}>
        <div class="multicolumn__media aspect-ratio" style="--aspect-ratio: {{ section.settings.tile_aspect_ratio }};">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 600 | image_tag: widths: '300,450,600', alt: block.settings.title, class: 'multicolumn__image', loading: 'lazy' }}
          {%- endif -%}

          {%- if section.settings.enable_hover_media -%}
            {%- if block.settings.hover_video != blank -%}
              {{ block.settings.hover_video | video_tag: image_size: '600x', autoplay: true, loop: true, muted: true, controls: false, class: 'multicolumn__hover-media' }}
            {%- elsif block.settings.hover_image != blank -%}
              {{ block.settings.hover_image | image_url: width: 600 | image_tag: widths: '300,450,600', alt: '', class: 'multicolumn__hover-media', loading: 'lazy' }}
            {%- endif -%}
          {%- endif -%}

          <span class="multicolumn__overlay"></span>
          <span class="multicolumn__tile-title">{{ block.settings.title }}</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .multicolumn {
    padding-block: var(--section-spacing);
  }

  .multicolumn__title {
    text-align: center;
    text-transform: uppercase;
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    margin-bottom: 1.5rem;
  }

  .multicolumn__grid {
    display: grid;
    grid-template-columns: repeat(var(--columns-mobile, 2), 1fr);
    gap: var(--multicolumn-gap, 1rem);
  }

  .multicolumn__tile {
    display: block;
    color: rgb(var(--color-text));
    text-align: center;
  }

  .multicolumn__media {
    position: relative;
    border-radius: var(--multicolumn-radius, var(--radius-lg));
    overflow: hidden;
    background: rgb(var(--color-background-alt));
  }

  .multicolumn__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .multicolumn__hover-media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity var(--transition-medium);
  }

  .multicolumn__tile:hover .multicolumn__hover-media {
    opacity: 1;
  }

  .multicolumn__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--multicolumn-overlay-color, #000), transparent 60%);
    opacity: var(--multicolumn-overlay-opacity, .35);
  }

  .multicolumn__tile-title {
    position: absolute;
    inset-inline: 0;
    display: block;
    padding: 0 1rem;
    color: var(--multicolumn-title-color, #fff);
    font-size: var(--multicolumn-title-size, 1.5rem);
    text-transform: var(--multicolumn-title-transform, uppercase);
    font-family: var(--font-body);
    font-weight: var(--font-body-weight-demibold);
  }

  .multicolumn__tile--title-top .multicolumn__tile-title { top: 1.25rem; }
  .multicolumn__tile--title-center .multicolumn__tile-title { top: 50%; transform: translateY(-50%); }
  .multicolumn__tile--title-bottom .multicolumn__tile-title { bottom: 1.25rem; }

  @media screen and (min-width: 45em) {
    .multicolumn__grid {
      grid-template-columns: repeat(var(--columns-desktop, 6), 1fr);
    }
  }

  /* Touch devices can't hover — always show hover media if present, matching
     the source site's mobile behavior of never rendering the static-only state. */
  @media (hover: none) {
    .multicolumn__hover-media {
      opacity: 1;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.multicolumn.name",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "shop by category",
      "label": "t:sections.multicolumn.title.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 6,
      "label": "t:sections.multicolumn.columns_desktop.label"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2,
      "label": "t:sections.multicolumn.columns_mobile.label"
    },
    {
      "type": "checkbox",
      "id": "enable_hover_media",
      "default": true,
      "label": "t:sections.multicolumn.enable_hover_media.label",
      "info": "t:sections.multicolumn.enable_hover_media.info"
    },
    {
      "type": "header",
      "content": "t:sections.multicolumn.tile_style_header"
    },
    {
      "type": "select",
      "id": "tile_aspect_ratio",
      "options": [
        { "value": "75%", "label": "t:sections.multicolumn.tile_aspect_ratio.landscape" },
        { "value": "100%", "label": "t:sections.multicolumn.tile_aspect_ratio.square" },
        { "value": "125%", "label": "t:sections.multicolumn.tile_aspect_ratio.portrait" },
        { "value": "150%", "label": "t:sections.multicolumn.tile_aspect_ratio.tall" }
      ],
      "default": "100%",
      "label": "t:sections.multicolumn.tile_aspect_ratio.label"
    },
    {
      "type": "range",
      "id": "tile_gap",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16,
      "label": "t:sections.multicolumn.tile_gap.label"
    },
    {
      "type": "range",
      "id": "tile_radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 10,
      "label": "t:sections.multicolumn.tile_radius.label"
    },
    {
      "type": "header",
      "content": "t:sections.multicolumn.title_style_header"
    },
    {
      "type": "select",
      "id": "title_position",
      "options": [
        { "value": "top", "label": "t:sections.common.align.top" },
        { "value": "center", "label": "t:sections.common.align.center" },
        { "value": "bottom", "label": "t:sections.common.align.bottom" }
      ],
      "default": "center",
      "label": "t:sections.multicolumn.title_position.label"
    },
    {
      "type": "color",
      "id": "title_color",
      "default": "#ffffff",
      "label": "t:sections.multicolumn.title_color.label"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24,
      "label": "t:sections.multicolumn.title_font_size.label"
    },
    {
      "type": "select",
      "id": "title_text_transform",
      "options": [
        { "value": "lowercase", "label": "t:sections.common.text_transform.lowercase" },
        { "value": "uppercase", "label": "t:sections.common.text_transform.uppercase" },
        { "value": "capitalize", "label": "t:sections.common.text_transform.capitalize" },
        { "value": "none", "label": "t:sections.common.text_transform.none" }
      ],
      "default": "uppercase",
      "label": "t:sections.multicolumn.title_text_transform.label"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "default": "#000000",
      "label": "t:sections.multicolumn.overlay_color.label"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 35,
      "label": "t:sections.multicolumn.overlay_opacity.label"
    },
    {
      "type": "select",
      "id": "font_override",
      "options": [
        { "value": "inherit", "label": "t:sections.common.font.inherit" },
        { "value": "heading", "label": "t:sections.common.font.heading" },
        { "value": "body", "label": "t:sections.common.font.body" },
        { "value": "accent", "label": "t:sections.common.font.accent" }
      ],
      "default": "inherit",
      "label": "t:sections.common.font.label"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "t:sections.multicolumn.blocks.tile.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.multicolumn.blocks.tile.image.label"
        },
        {
          "type": "video",
          "id": "hover_video",
          "label": "t:sections.multicolumn.blocks.tile.hover_video.label"
        },
        {
          "type": "image_picker",
          "id": "hover_image",
          "label": "t:sections.multicolumn.blocks.tile.hover_image.label",
          "info": "t:sections.multicolumn.blocks.tile.hover_image.info"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.multicolumn.blocks.tile.title.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.multicolumn.blocks.tile.link.label"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "t:sections.multicolumn.name",
      "blocks": [
        { "type": "tile", "settings": { "title": "lips" } },
        { "type": "tile", "settings": { "title": "fragrance" } },
        { "type": "tile", "settings": { "title": "face" } },
        { "type": "tile", "settings": { "title": "blush" } },
        { "type": "tile", "settings": { "title": "Lip Care" } },
        { "type": "tile", "settings": { "title": "eyes" } }
      ]
    }
  ]
}
{% endschema %}
