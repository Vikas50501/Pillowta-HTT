{% comment %}
  Manual shoppable-video gallery. Originally wired to the third-party Firework
  (fw.tv) platform (auto-pulled videos via an external paid account); replaced
  with merchant-uploaded blocks (video + optional poster/link) per the site
  owner's choice, since the third-party service needs a separate paid signup —
  this needs zero external accounts and updates directly through the Theme Editor.
{% endcomment %}
<div
  id="shopify-section-{{ section.id }}"
  class="fireworks{% if section.settings.font_override != 'inherit' %} fireworks--font-{{ section.settings.font_override }}{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="fireworks"
>
  {%- if section.settings.title != blank -%}
    <h2 class="fireworks__title page-width">{{ section.settings.title }}</h2>
  {%- endif -%}

  {%- liquid
    assign wrapper_tag = 'div'
    if section.settings.mode == 'row'
      assign wrapper_tag = 'product-carousel'
    endif
  -%}
  <{{ wrapper_tag }}
    class="fireworks__track fireworks__track--{{ section.settings.mode }} page-width"
    style="
      --columns-desktop: {{ section.settings.columns_desktop }};
      --columns-mobile: {{ section.settings.columns_mobile }};
      --fireworks-gap: {{ section.settings.tile_gap }}px;
      --fireworks-radius: {{ section.settings.tile_radius }}px;
      --fireworks-caption-color: {{ section.settings.caption_color }};
    "
  >
    <div class="fireworks__tiles" {% if section.settings.mode == 'row' %}data-carousel-track{% endif %}>
      {%- for block in section.blocks -%}
        {%- liquid
          assign tile_tag = 'div'
          if block.settings.link != blank
            assign tile_tag = 'a'
          endif
        -%}
        <{{ tile_tag }}
          {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
          class="fireworks__tile"
          {% if section.settings.mode == 'row' %}data-carousel-slide{% endif %}
          {{ block.shopify_attributes }}
        >
          <div class="fireworks__media">
            {%- if block.settings.video != blank -%}
              {{ block.settings.video | video_tag: image_size: '600x', autoplay: section.settings.autoplay, loop: true, muted: true, controls: false, class: 'fireworks__video' }}
            {%- elsif block.settings.poster != blank -%}
              {{ block.settings.poster | image_url: width: 600 | image_tag: widths: '300,450,600', alt: block.settings.caption, class: 'fireworks__poster', loading: 'lazy' }}
            {%- endif -%}

            {%- if section.settings.show_captions and block.settings.caption != blank -%}
              <span class="fireworks__caption">{{ block.settings.caption }}</span>
            {%- endif -%}
          </div>
        </{{ tile_tag }}>
      {%- endfor -%}
    </div>

    {%- if section.settings.mode == 'row' -%}
      <button type="button" class="fireworks__nav fireworks__nav--prev" data-carousel-prev aria-label="{{ 'accessibility.previous' | t }}">{%- render 'icon', name: 'chevron-left' -%}</button>
      <button type="button" class="fireworks__nav fireworks__nav--next" data-carousel-next aria-label="{{ 'accessibility.next' | t }}">{%- render 'icon', name: 'chevron-right' -%}</button>
    {%- endif -%}
  </{{ wrapper_tag }}>
</div>

{% stylesheet %}
  .fireworks {
    padding-block: var(--section-spacing);
  }

  .fireworks__title {
    text-align: center;
    text-transform: uppercase;
    color: rgb(var(--color-accent));
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    margin-bottom: 1.5rem;
  }

  .fireworks__track--row {
    position: relative;
  }

  .fireworks__track--grid .fireworks__tiles {
    display: grid;
    grid-template-columns: repeat(var(--columns-mobile, 2), 1fr);
    gap: var(--fireworks-gap, 16px);
  }

  .fireworks__track--row .fireworks__tiles {
    display: flex;
    gap: var(--fireworks-gap, 16px);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .fireworks__track--row .fireworks__tiles::-webkit-scrollbar {
    display: none;
  }

  .fireworks__track--row .fireworks__tile {
    flex: 0 0 calc((100% - (var(--columns-mobile, 2) - 1) * var(--fireworks-gap, 16px)) / var(--columns-mobile, 2));
    scroll-snap-align: start;
  }

  .fireworks__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgb(var(--color-background));
    border: 1px solid rgb(var(--color-border));
    border-radius: 50%;
    width: 2.5rem;
    height: 2.5rem;
    cursor: pointer;
  }

  .fireworks__nav--prev { left: -1.25rem; }
  .fireworks__nav--next { right: -1.25rem; }

  .fireworks__tile {
    position: relative;
    display: block;
    aspect-ratio: 9 / 16;
    border-radius: var(--fireworks-radius, 10px);
    overflow: hidden;
    background: rgb(var(--color-background-alt));
  }

  .fireworks__video,
  .fireworks__poster {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fireworks__caption {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding: .75rem;
    color: var(--fireworks-caption-color, #fff);
    background: linear-gradient(to top, rgba(0, 0, 0, .55), transparent);
    font-family: var(--font-body);
    font-weight: var(--font-body-weight-demibold);
  }

  @media screen and (min-width: 45em) {
    .fireworks__track--grid .fireworks__tiles {
      grid-template-columns: repeat(var(--columns-desktop, 5), 1fr);
    }

    .fireworks__track--row .fireworks__tile {
      flex-basis: calc((100% - (var(--columns-desktop, 5) - 1) * var(--fireworks-gap, 16px)) / var(--columns-desktop, 5));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.fireworks.name",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "LOVE FOR COSMIC",
      "label": "t:sections.fireworks.title.label"
    },
    {
      "type": "select",
      "id": "mode",
      "options": [
        { "value": "row", "label": "t:sections.fireworks.mode.row" },
        { "value": "grid", "label": "t:sections.fireworks.mode.grid" }
      ],
      "default": "row",
      "label": "t:sections.fireworks.mode.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 5,
      "label": "t:sections.fireworks.columns_desktop.label"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2,
      "label": "t:sections.fireworks.columns_mobile.label"
    },
    {
      "type": "range",
      "id": "tile_gap",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16,
      "label": "t:sections.fireworks.tile_gap.label"
    },
    {
      "type": "range",
      "id": "tile_radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 10,
      "label": "t:sections.fireworks.tile_radius.label"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "default": true,
      "label": "t:sections.fireworks.autoplay.label",
      "info": "t:sections.fireworks.autoplay.info"
    },
    {
      "type": "checkbox",
      "id": "show_captions",
      "default": true,
      "label": "t:sections.fireworks.show_captions.label"
    },
    {
      "type": "color",
      "id": "caption_color",
      "default": "#ffffff",
      "label": "t:sections.fireworks.caption_color.label"
    },
    {
      "type": "select",
      "id": "font_override",
      "options": [
        { "value": "inherit", "label": "t:sections.common.font.inherit" },
        { "value": "heading", "label": "t:sections.common.font.heading" },
        { "value": "body", "label": "t:sections.common.font.body" },
        { "value": "accent", "label": "t:sections.common.font.accent" }
      ],
      "default": "inherit",
      "label": "t:sections.common.font.label"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "t:sections.fireworks.blocks.video.name",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "t:sections.fireworks.blocks.video.video.label"
        },
        {
          "type": "image_picker",
          "id": "poster",
          "label": "t:sections.fireworks.blocks.video.poster.label",
          "info": "t:sections.fireworks.blocks.video.poster.info"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "t:sections.fireworks.blocks.video.caption.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.fireworks.blocks.video.link.label",
          "info": "t:sections.fireworks.blocks.video.link.info"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "t:sections.fireworks.name",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}
