{% comment %}
  Maps to: source site's <header class="layout__header"> Vue app — top bar
  (country/currency selector left, logo centered, icons right) + a separate
  centered nav row below (desktop mega-menu: Cosmetics/Fragrance/Skin/discover).
  Mobile drawer adds a mobile-only "rewards" 5th item. Transparent-over-hero →
  solid-on-scroll header, correctly offset below the always-visible announcement
  bar (measured live via JS, since the announcement bar's height varies with
  content/viewport and isn't a fixed value we can hard-code in CSS).
{% endcomment %}
<div
  id="shopify-section-{{ section.id }}"
  class="site-header site-header--{{ section.settings.layout_style }}{% if section.settings.transparent_on_home and request.page_type == 'index' %} site-header--transparent{% endif %}{% if section.settings.transparent_logo != blank %} has-transparent-logo{% endif %}{% if section.settings.font_override != 'inherit' %} site-header--font-{{ section.settings.font_override }}{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="header"
  data-sticky="{{ section.settings.sticky }}"
  style="
    --header-bg: {{ section.settings.color_background }};
    --header-text: {{ section.settings.color_text }};
    --header-border: {{ section.settings.color_border }};
    --header-transparent-text: {{ section.settings.transparent_text_color }};
    --header-icon-size: {{ section.settings.icon_size }}px;
    --header-nav-font-size: {{ section.settings.nav_font_size }}px;
    --header-nav-gap: {{ section.settings.nav_gap }}px;
    --header-nav-link-color: {{ section.settings.nav_link_color }};
    --header-nav-link-hover-color: {{ section.settings.nav_link_hover_color }};
    --header-cart-badge-bg: {{ section.settings.cart_badge_bg_color }};
    --header-cart-badge-text: {{ section.settings.cart_badge_text_color }};
    --mega-menu-bg: {{ section.settings.mega_menu_bg_color }};
    --mega-menu-text: {{ section.settings.mega_menu_text_color }};
  "
>
  <div class="site-header__topbar page-width">
    <div class="site-header__topbar-start">
      <button type="button" class="site-header__mobile-toggle" data-drawer-open="MobileMenu" aria-label="{{ 'accessibility.open_menu' | t }}">
        {%- render 'icon', name: 'menu', size: section.settings.icon_size -%}
      </button>

      {%- if section.settings.show_localization and localization.available_countries.size > 1 -%}
        {% form 'localization', id: 'HeaderLocalizationForm', class: 'localization-form' %}
          <label class="visually-hidden" for="HeaderCountrySelect">{{ 'localization.country_label' | t: default: 'Country/region' }}</label>
          <select name="country_code" id="HeaderCountrySelect" class="localization-form__select" onchange="this.form.submit()">
            {%- for country in localization.available_countries -%}
              <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
                {{ country.iso_code }} ({{ country.currency.symbol }})
              </option>
            {%- endfor -%}
          </select>
        {% endform %}
      {%- endif -%}
    </div>

    <h1 class="site-logo" style="--logo-width: {{ section.settings.logo_width }}px; --logo-max-height: {{ section.settings.logo_max_height }}px;">
      <a href="{{ routes.root_url }}" title="{{ shop.name }} {{ 'general.home_page' | t: default: 'home page' }}">
        {%- if section.settings.transparent_logo != blank -%}
          {{ section.settings.transparent_logo | image_url: width: section.settings.logo_width | image_tag: widths: '100,200,300', alt: shop.name, class: 'site-logo__image site-logo__image--transparent' }}
        {%- endif -%}
        {%- if section.settings.logo != blank -%}
          {{ section.settings.logo | image_url: width: section.settings.logo_width | image_tag: widths: '100,200,300', alt: shop.name, class: 'site-logo__image site-logo__image--solid' }}
        {%- else -%}
          <span class="site-logo__text site-logo__image--solid">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </h1>

    <div class="site-header__actions">
      {%- if section.settings.show_search -%}
        <button type="button" class="site-header__action site-header__action--search" data-drawer-open="SearchDrawer" aria-label="{{ 'accessibility.search' | t: default: 'Search' }}">
          {%- render 'icon', name: 'search', size: section.settings.icon_size -%}
        </button>
      {%- endif -%}
      {%- if section.settings.show_wishlist -%}
        <a href="{{ routes.root_url }}pages/wishlist" class="site-header__action site-header__action--wishlist" aria-label="{{ 'accessibility.wishlist' | t: default: 'Wishlist' }}">
          {%- render 'icon', name: 'wishlist', size: section.settings.icon_size -%}
        </a>
      {%- endif -%}
      {%- if section.settings.show_account -%}
        <a href="{{ routes.account_url }}" class="site-header__action site-header__action--account" aria-label="{{ 'accessibility.account' | t: default: 'Account' }}">
          {%- render 'icon', name: 'account', size: section.settings.icon_size -%}
        </a>
      {%- endif -%}
      <button type="button" class="site-header__action site-header__action--cart" data-drawer-open="CartDrawer" aria-label="{{ 'accessibility.cart' | t: default: 'Cart' }}">
        {%- render 'icon', name: 'cart', size: section.settings.icon_size -%}
        <span class="site-header__cart-count" data-cart-count>{{ cart.item_count }}</span>
      </button>
    </div>
  </div>

  <nav class="linklist linklist--main-menu linklist--desktop site-header__nav-row" aria-label="{{ 'accessibility.main_menu' | t: default: 'Main menu' }}">
    <ul class="site-header__nav">
      {%- for link in section.settings.main_menu.links -%}
        <li class="site-header__nav-item{% if link.links.size > 0 %} link--has-children link--has-mega-menu{% endif %}">
          <a href="{{ link.url }}" class="site-header__link" {% if link.links.size > 0 %}aria-expanded="false" aria-haspopup="true"{% endif %}>
            {{ link.title }}
          </a>
          {%- if link.links.size > 0 -%}
            {%- render 'mega-menu', link: link, section: section -%}
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </nav>

  {%- render 'mobile-menu', section: section -%}
</div>

{% stylesheet %}
  .site-header {
    position: relative;
    background-color: rgb(var(--color-background));
    background-color: var(--header-bg, rgb(var(--color-background)));
    color: var(--header-text, rgb(var(--color-text)));
    font-family: var(--font-body);
    z-index: 30;
  }

  /* :not(.site-header--transparent) so this never competes on specificity
     with the transparent-state rules below when both sticky and
     transparent_on_home are enabled together (a common combination) -
     an attribute selector like [data-sticky='true'] otherwise beats a
     plain class selector regardless of source order, silently overriding
     position: absolute with position: sticky and defeating the overlay. */
  .site-header[data-sticky='true']:not(.site-header--transparent) {
    position: sticky;
    top: 0;
  }

  /* ---- Transparent-over-hero state (homepage only) ----
     Offset by --announcement-bar-height (set via JS below) so the transparent
     header floats correctly below the always-visible announcement bar instead
     of overlapping/fighting with it at the very top of the page. */
  .site-header--transparent {
    position: absolute;
    inset-inline: 0;
    top: var(--announcement-bar-height, 0px);
    background-color: transparent;
    color: var(--header-transparent-text, #fff);
    transition: background-color .2s ease, color .2s ease;
  }

  /* While still floating over the hero (not yet scrolled), hovering
     anywhere on the header turns it solid for readability, then reverts to
     transparent on mouseout. */
  .site-header--transparent:not(.site-header--active):hover {
    background-color: var(--header-bg, rgb(var(--color-background)));
    color: var(--header-text, rgb(var(--color-text)));
  }

  .site-header--transparent.has-transparent-logo:not(.site-header--active):hover .site-logo__image--transparent {
    display: none;
  }

  .site-header--transparent.has-transparent-logo:not(.site-header--active):hover .site-logo__image--solid {
    display: block;
  }

  .site-header--transparent.site-header--active {
    position: sticky;
    top: 0;
    background-color: var(--header-bg, rgb(var(--color-background)));
    color: var(--header-text, rgb(var(--color-text)));
    box-shadow: 0 1px 0 var(--header-border, rgba(var(--color-border), 1));
    transition: background-color .3s ease, color .3s ease;
  }

  /* Once scrolled past the hero, respect Sticky = off: turn solid like
     normal but let it scroll away with the page instead of forcing it to
     stick, which previously happened unconditionally regardless of the
     Sticky toggle. */
  .site-header--transparent.site-header--active[data-sticky='false'] {
    position: relative;
  }

  /* ---- Top bar: 3-column grid so the logo is always perfectly centered
     regardless of how much content sits in the start/end slots ---- */
  .site-header__topbar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding-top: .875rem;
    padding-bottom: .875rem;
  }

  .site-header__topbar-start {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .site-header__mobile-toggle {
    display: none;
    background: none;
    border: 0;
    color: inherit;
    cursor: pointer;
  }

  .localization-form__select {
    background: none;
    border: 1px solid currentColor;
    border-radius: var(--radius-sm);
    color: inherit;
    padding: .25rem .5rem;
    font-size: var(--font-size-caption);
  }

  .site-logo {
    margin: 0;
    line-height: 0;
    text-align: center;
    grid-column: 2;
  }

  .site-logo__image {
    /* Both settings act as caps on the same bounding box (like object-fit:
       contain) so "Logo image width" actually has a visible effect instead
       of being silently capped out by max-height alone. */
    width: auto;
    height: auto;
    max-width: var(--logo-width, 130px);
    max-height: var(--logo-max-height, 48px);
  }

  /* Swap to a dedicated light/white logo while floating transparently over
     the hero, since a raster logo image can't be recolored with CSS `color`
     the way inline SVG/text can. Falls back to always showing the regular
     logo if no transparent-state logo was uploaded. */
  .site-logo__image--transparent {
    display: none;
  }

  .site-header--transparent.has-transparent-logo:not(.site-header--active) .site-logo__image--transparent {
    display: block;
  }

  .site-header--transparent.has-transparent-logo:not(.site-header--active) .site-logo__image--solid {
    display: none;
  }

  .site-logo__text {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: 1.5rem;
    letter-spacing: .05em;
    text-transform: uppercase;
    color: inherit;
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
  }

  .site-header__action {
    position: relative;
    display: inline-flex;
    background: none;
    border: 0;
    color: inherit;
    cursor: pointer;
  }

  .site-header__action svg {
    width: var(--header-icon-size, 20px);
    height: var(--header-icon-size, 20px);
  }

  .site-header__action:focus-visible {
    outline: 2px solid rgb(var(--color-focus-outline));
  }

  .site-header__cart-count {
    position: absolute;
    top: -6px;
    right: -8px;
    min-width: 16px;
    height: 16px;
    padding: 0 3px;
    border-radius: 50%;
    background: var(--header-cart-badge-bg, rgb(var(--color-accent)));
    color: var(--header-cart-badge-text, #fff);
    font-size: 10px;
    line-height: 16px;
    text-align: center;
  }

  .site-header__cart-count:empty,
  .site-header__cart-count[data-cart-count='0'] {
    display: none;
  }

  /* ---- Centered nav row (below the top bar) — real site's default layout ---- */
  .site-header__nav-row {
    display: flex;
    justify-content: center;
  }

  .site-header--inline .site-header__nav-row {
    display: none;
  }

  .site-header--inline .site-header__topbar {
    grid-template-columns: auto 1fr auto;
  }

  .site-header--inline .site-logo {
    grid-column: 1;
    text-align: left;
  }

  .site-header--inline .site-header__topbar-start {
    display: none;
  }

  .site-header__nav {
    display: flex;
    gap: var(--header-nav-gap, 1.75rem);
    padding-block: .625rem;
  }

  .site-header__link {
    display: block;
    padding: .5rem 0;
    color: var(--header-nav-link-color, inherit);
    text-transform: {{ section.settings.nav_text_transform }};
    font-size: var(--header-nav-font-size, var(--font-size-small));
    transition: color var(--transition-fast);
  }

  .site-header__link:hover {
    color: var(--header-nav-link-hover-color, rgb(var(--color-accent)));
  }

  /* While floating transparently over the hero (not yet scrolled), nav links
     ignore the custom nav_link_color and inherit the header's transparent
     text color instead - otherwise a dark default nav color would always win
     and the nav row would never turn white/light over a dark hero image. */
  .site-header--transparent:not(.site-header--active) .site-header__link {
    color: inherit;
  }

  .site-header--transparent:not(.site-header--active) .site-header__link:hover {
    color: inherit;
    opacity: .7;
  }

  .link--has-mega-menu:hover .mega-menu,
  .link--has-mega-menu:focus-within .mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  @media screen and (max-width: 74.99em) {
    .site-header__mobile-toggle {
      display: inline-flex;
    }
    .site-header__nav-row {
      display: none;
    }
    .site-header__topbar {
      grid-template-columns: auto 1fr auto;
    }
    .site-header__topbar-start {
      gap: .5rem;
    }
    .localization-form {
      display: none;
    }
  }

  /* ---- Mega menu (snippets/mega-menu.liquid) ---- */
  .mega-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity .2s ease, transform .2s ease, visibility .2s;
    background: var(--mega-menu-bg, rgb(var(--color-background)));
    color: var(--mega-menu-text, rgb(var(--color-text)));
    border-top: 1px solid rgb(var(--color-border));
    box-shadow: 0 12px 24px rgba(0, 0, 0, .08);
  }

  .mega-menu__grid {
    display: flex;
    gap: var(--grid-gutter);
    padding: 2.5rem 0;
  }

  .mega-menu__main {
    display: flex;
    flex: 1;
    gap: var(--grid-gutter);
  }

  .mega-menu__column-title {
    display: block;
    margin-bottom: .75rem;
    font-family: var(--font-body);
    font-weight: var(--font-body-weight-demibold);
    text-transform: lowercase;
    color: inherit;
  }

  .mega-menu__column-list li + li {
    margin-top: .5rem;
  }

  .mega-menu__column-link {
    color: inherit;
    opacity: .8;
    font-size: var(--font-size-small);
  }

  .mega-menu__column-link:hover {
    opacity: 1;
    color: rgb(var(--color-accent));
  }

  .mega-menu__aside {
    width: 18rem;
    flex-shrink: 0;
  }

  .banner-block__title {
    margin-top: .5rem;
    font-family: var(--font-body);
    font-weight: var(--font-body-weight-demibold);
    text-align: center;
  }

  /* ---- Mobile menu drawer (snippets/mobile-menu.liquid + mobile-menu-level.liquid) ---- */
  .mobile-menu {
    position: fixed;
    inset: 0 auto 0 0;
    width: min(90vw, 380px);
    background: rgb(var(--color-background));
    transform: translateX(-100%);
    transition: transform var(--transition-slow);
    z-index: 60;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  .mobile-menu[open] {
    transform: translateX(0);
  }

  .mobile-menu::backdrop,
  .mobile-menu[open]::before {
    content: '';
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, .5);
    z-index: -1;
  }

  .mobile-menu__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem;
    border-bottom: 1px solid rgb(var(--color-border));
  }

  .mobile-menu__header button {
    background: none;
    border: 0;
    cursor: pointer;
  }

  .mobile-menu__utilities {
    display: flex;
    flex-direction: column;
    gap: .5rem;
    padding: 1rem;
    border-bottom: 1px solid rgb(var(--color-border));
  }

  .mobile-menu__utility-link {
    display: flex;
    align-items: center;
    gap: .5rem;
    color: rgb(var(--color-text));
  }

  .mobile-menu__nav {
    padding: .5rem 1rem 2rem;
  }

  .mobile-menu__link,
  .mobile-menu__sublink-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: .875rem 0;
    border: 0;
    background: none;
    color: rgb(var(--color-text));
    font-size: var(--font-size-body);
    text-align: left;
    text-transform: lowercase;
    border-bottom: 1px solid rgb(var(--color-border));
    cursor: pointer;
  }

  .mobile-menu__sublist {
    max-height: 0;
    overflow: hidden;
    transition: max-height .35s linear;
  }

  .mobile-menu__item.is-open > .mobile-menu__sublist {
    max-height: 1200px;
  }

  .mobile-menu__sublink-toggle svg {
    transition: transform var(--transition-fast);
  }

  .mobile-menu__item.is-open > .mobile-menu__sublink-toggle svg {
    transform: rotate(180deg);
  }

  @media screen and (min-width: 75em) {
    .mobile-menu {
      display: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    // Measure the announcement bar's real rendered height and expose it as a
    // CSS variable so a transparent header can offset itself below it
    // instead of overlapping the top of the page.
    function updateAnnouncementBarHeight() {
      const bar = document.querySelector('[data-section-type="announcement-bar"]');
      const height = bar && !bar.hasAttribute('hidden') ? bar.offsetHeight : 0;
      document.documentElement.style.setProperty('--announcement-bar-height', height + 'px');
    }
    updateAnnouncementBarHeight();
    window.addEventListener('resize', updateAnnouncementBarHeight);
    window.addEventListener('load', updateAnnouncementBarHeight);
    document.addEventListener('theme:announcement-bar:dismissed', updateAnnouncementBarHeight);

    document.querySelectorAll('[data-section-type="header"]').forEach((header) => {
      if (header.dataset.sticky !== 'true' && !header.classList.contains('site-header--transparent')) return;
      const onScroll = () => {
        header.classList.toggle('site-header--active', window.scrollY > 40);
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    });

    document.addEventListener('cart:updated', (e) => {
      document.querySelectorAll('[data-cart-count]').forEach((el) => {
        el.textContent = e.detail.item_count;
        el.dataset.cartCount = e.detail.item_count;
      });
    });

    // Mobile menu accordion (snippets/mobile-menu-level.liquid sublinks)
    document.querySelectorAll('.mobile-menu__sublink-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.mobile-menu__item');
        const isOpen = item.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', isOpen);
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.header.name",
  "settings": [
    {
      "type": "select",
      "id": "layout_style",
      "options": [
        { "value": "centered", "label": "t:sections.header.layout_style.centered" },
        { "value": "inline", "label": "t:sections.header.layout_style.inline" }
      ],
      "default": "centered",
      "label": "t:sections.header.layout_style.label",
      "info": "t:sections.header.layout_style.info"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "default": "main-menu",
      "label": "t:sections.header.main_menu.label"
    },
    {
      "type": "header",
      "content": "t:sections.header.logo_header"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:sections.header.logo.label"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 260,
      "step": 5,
      "unit": "px",
      "default": 130,
      "label": "t:sections.header.logo_width.label"
    },
    {
      "type": "range",
      "id": "logo_max_height",
      "min": 24,
      "max": 96,
      "step": 2,
      "unit": "px",
      "default": 48,
      "label": "t:sections.header.logo_max_height.label",
      "info": "t:sections.header.logo_max_height.info"
    },
    {
      "type": "image_picker",
      "id": "transparent_logo",
      "label": "t:sections.header.transparent_logo.label",
      "info": "t:sections.header.transparent_logo.info"
    },
    {
      "type": "header",
      "content": "t:sections.header.icons_header"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "default": true,
      "label": "t:sections.header.show_search.label"
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "default": true,
      "label": "t:sections.header.show_wishlist.label"
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "default": true,
      "label": "t:sections.header.show_account.label"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 20,
      "label": "t:sections.header.icon_size.label"
    },
    {
      "type": "header",
      "content": "t:sections.header.nav_header"
    },
    {
      "type": "select",
      "id": "nav_text_transform",
      "options": [
        { "value": "lowercase", "label": "t:sections.common.text_transform.lowercase" },
        { "value": "uppercase", "label": "t:sections.common.text_transform.uppercase" },
        { "value": "capitalize", "label": "t:sections.common.text_transform.capitalize" },
        { "value": "none", "label": "t:sections.common.text_transform.none" }
      ],
      "default": "lowercase",
      "label": "t:sections.header.nav_text_transform.label"
    },
    {
      "type": "range",
      "id": "nav_font_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15,
      "label": "t:sections.header.nav_font_size.label"
    },
    {
      "type": "range",
      "id": "nav_gap",
      "min": 8,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28,
      "label": "t:sections.header.nav_gap.label"
    },
    {
      "type": "header",
      "content": "t:sections.header.colors_header"
    },
    {
      "type": "color",
      "id": "color_background",
      "default": "#ffffff",
      "label": "t:sections.header.color_background.label"
    },
    {
