{% comment %}
  Maps to: source site's theme.brand_principles config (shopify-section-brand-principles)
  — a horizontal row of icon+title trust badges (vegan, cruelty free, clean, etc.),
  the source has ~32 possible entries; seeded here with the 8 most common ones.
{% endcomment %}
<div
  id="shopify-section-{{ section.id }}"
  class="brand-principles{% if section.settings.font_override != 'inherit' %} brand-principles--font-{{ section.settings.font_override }}{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="brand-principles"
>
  <ul class="brand-principles__list page-width" data-scroll-reveal>
    {%- for block in section.blocks -%}
      <li class="brand-principles__item" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 96 | image_tag: widths: '48,96', alt: block.settings.title, class: 'brand-principles__icon', loading: 'lazy' }}
        {%- elsif block.settings.icon_asset != blank -%}
          <img src="{{ block.settings.icon_asset | asset_url }}" width="48" height="48" alt="{{ block.settings.title }}" class="brand-principles__icon" loading="lazy">
        {%- endif -%}
        <span class="brand-principles__title">{{ block.settings.title }}</span>
      </li>
    {%- endfor -%}
  </ul>
</div>

{% stylesheet %}
  .brand-principles {
    padding-block: var(--section-spacing);
    background-color: rgb(var(--color-background-alt));
  }

  .brand-principles__list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
  }

  .brand-principles__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .5rem;
    width: 6rem;
    text-align: center;
  }

  .brand-principles__icon {
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-full);
  }

  .brand-principles__title {
    font-size: var(--font-size-caption);
    text-transform: lowercase;
    color: rgb(var(--color-text));
  }

  @media screen and (max-width: 44.99em) {
    .brand-principles__list {
      gap: 1.25rem;
      overflow-x: auto;
      flex-wrap: nowrap;
      justify-content: flex-start;
      scroll-snap-type: x mandatory;
    }
    .brand-principles__item {
      flex-shrink: 0;
      scroll-snap-align: start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.brand-principles.name",
  "settings": [
    {
      "type": "select",
      "id": "font_override",
      "options": [
        { "value": "inherit", "label": "t:sections.common.font.inherit" },
        { "value": "heading", "label": "t:sections.common.font.heading" },
        { "value": "body", "label": "t:sections.common.font.body" },
        { "value": "accent", "label": "t:sections.common.font.accent" }
      ],
      "default": "inherit",
      "label": "t:sections.common.font.label"
    }
  ],
  "blocks": [
    {
      "type": "principle",
      "name": "t:sections.brand-principles.blocks.principle.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.brand-principles.blocks.principle.image.label",
          "info": "t:sections.brand-principles.blocks.principle.image.info"
        },
        {
          "type": "text",
          "id": "icon_asset",
          "label": "t:sections.brand-principles.blocks.principle.icon_asset.label",
          "info": "t:sections.brand-principles.blocks.principle.icon_asset.info"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.brand-principles.blocks.principle.title.label"
        }
      ]
    }
  ],
  "max_blocks": 32,
  "presets": [
    {
      "name": "t:sections.brand-principles.name",
      "blocks": [
        { "type": "principle", "settings": { "icon_asset": "icon-vegan.png", "title": "vegan" } },
        { "type": "principle", "settings": { "icon_asset": "icon-cruelty-free.png", "title": "cruelty free" } },
        { "type": "principle", "settings": { "icon_asset": "icon-clean.png", "title": "clean" } },
        { "type": "principle", "settings": { "icon_asset": "icon-talc-free.png", "title": "talc free" } },
        { "type": "principle", "settings": { "icon_asset": "icon-gluten-free.png", "title": "gluten free" } },
        { "type": "principle", "settings": { "icon_asset": "icon-dermatologist-tested.png", "title": "dermatologist tested" } },
        { "type": "principle", "settings": { "icon_asset": "icon-paraben-free.png", "title": "paraben free" } },
        { "type": "principle", "settings": { "icon_asset": "icon-fragrance-free.png", "title": "fragrance free" } }
      ]
    }
  ]
}
{% endschema %}
