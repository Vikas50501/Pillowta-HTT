{% comment %}
  Maps to: source site's <div class="site-footer"> — Klaviyo newsletter embed,
  Facebook/Instagram/Twitter/TikTok social icons, a single flat footer nav
  (contact/faq/shipping/order-tracking/gift-card-balance/legal), copyright line.
  Rebuilt with Shopify's native customer form (no 3rd-party embed dependency) and
  repeatable link-list blocks so merchants can add more columns than the source had.
{% endcomment %}
<footer
  id="shopify-section-{{ section.id }}"
  class="site-footer{% if section.settings.font_override != 'inherit' %} site-footer--font-{{ section.settings.font_override }}{% endif %}{% unless section.settings.show_dividers %} site-footer--no-dividers{% endunless %}"
  data-section-id="{{ section.id }}"
  data-section-type="footer"
  style="
    {%- if section.settings.background_color != blank -%}
    --footer-bg: {{ section.settings.background_color }};
    {%- endif -%}
    {%- if section.settings.text_color != blank -%}
    --footer-text: {{ section.settings.text_color }};
    {%- endif -%}
    {%- if section.settings.heading_color != blank -%}
    --footer-heading: {{ section.settings.heading_color }};
    {%- endif -%}
    {%- if section.settings.link_color != blank -%}
    --footer-link: {{ section.settings.link_color }};
    {%- endif -%}
    {%- if section.settings.link_hover_color != blank -%}
    --footer-link-hover: {{ section.settings.link_hover_color }};
    {%- endif -%}
    {%- if section.settings.border_color != blank -%}
    --footer-border: {{ section.settings.border_color }};
    {%- endif -%}
    {%- if section.settings.icon_color != blank -%}
    --footer-icon-color: {{ section.settings.icon_color }};
    {%- endif -%}
    --footer-columns-align: {{ section.settings.columns_alignment }};
    --footer-icon-size: {{ section.settings.icon_size }}px;
    --footer-copyright-size: {{ section.settings.copyright_font_size }}px;
  ">
  <div class="site-footer__container page-width">
    {%- if section.settings.show_newsletter -%}
      <div class="site-footer__newsletter">
        <h2 class="site-footer__newsletter-title">{{ section.settings.newsletter_title }}</h2>
        {%- if section.settings.newsletter_subtext != blank -%}
          <p class="site-footer__newsletter-subtext">{{ section.settings.newsletter_subtext }}</p>
        {%- endif -%}
        {%- form 'customer', id: 'FooterNewsletterForm', class: 'site-footer__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label class="visually-hidden" for="FooterNewsletterEmail">{{ 'general.email' | t: default: 'Email' }}</label>
          <input
            type="email"
            id="FooterNewsletterEmail"
            name="contact[email]"
            placeholder="{{ 'general.email_placeholder' | t: default: 'Email address' }}"
            required
          >
          <button type="submit" class="action action--{{ section.settings.newsletter_button_style }}">
            {{ section.settings.newsletter_button_text }}
          </button>
          {%- if form.posted_successfully? -%}
            <p class="form__message form__message--success">{{ 'general.newsletter_success' | t: default: 'Thanks for subscribing!' }}</p>
          {%- endif -%}
        {%- endform -%}
      </div>
    {%- endif -%}

    <div class="site-footer__menus">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'link_list' -%}
            <nav class="site-footer__menu-column" {{ block.shopify_attributes }}>
              {%- if block.settings.title != blank -%}
                <p class="site-footer__menu-title">{{ block.settings.title }}</p>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="linklist linklist--footer">
                  {%- for link in block.settings.menu.links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </nav>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <ul class="site-footer__social-icons">
      {%- if settings.social_instagram != blank -%}
        <li class="social-icon"><a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">{% render 'icon', name: 'instagram', icon_size: section.settings.icon_size %}</a></li>
      {%- endif -%}
      {%- if settings.social_facebook != blank -%}
        <li class="social-icon"><a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">{% render 'icon', name: 'facebook', icon_size: section.settings.icon_size %}</a></li>
      {%- endif -%}
      {%- if settings.social_twitter != blank -%}
        <li class="social-icon"><a href="{{ settings.social_twitter }}" target="_blank" rel="noopener" aria-label="Twitter">{% render 'icon', name: 'twitter', icon_size: section.settings.icon_size %}</a></li>
      {%- endif -%}
      {%- if settings.social_tiktok != blank -%}
        <li class="social-icon"><a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">{% render 'icon', name: 'tiktok', icon_size: section.settings.icon_size %}</a></li>
      {%- endif -%}
      {%- if settings.social_youtube != blank -%}
        <li class="social-icon"><a href="{{ settings.social_youtube }}" target="_blank" rel="noopener" aria-label="YouTube">{% render 'icon', name: 'youtube', icon_size: section.settings.icon_size %}</a></li>
      {%- endif -%}
    </ul>

    <div class="site-footer__copyright">
      <p class="site-footer__copyright-text">
        &copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright_text | default: shop.name }}
      </p>
    </div>
  </div>
</footer>

{% stylesheet %}
  .site-footer {
    background-color: var(--footer-bg, rgb(var(--color-background-alt)));
    color: var(--footer-text, rgb(var(--color-text)));
    font-family: var(--font-body);
    padding-top: var(--section-spacing);
    padding-bottom: var(--section-spacing);
  }

  .site-footer__newsletter {
    text-align: center;
    max-width: 30rem;
    margin: 0 auto var(--section-spacing);
  }

  .site-footer__newsletter-title {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    color: var(--footer-heading, inherit);
  }

  .site-footer__newsletter-form {
    display: flex;
    gap: .5rem;
    margin-top: 1rem;
  }

  .site-footer__newsletter-form input[type='email'] {
    flex: 1;
    padding: 0 1rem;
    height: 2.5rem;
    border: 1px solid var(--footer-border, rgb(var(--color-border)));
    border-radius: var(--radius-sm);
    background: rgb(var(--color-background));
  }

  .site-footer__menus {
    display: flex;
    flex-wrap: wrap;
    gap: var(--grid-gutter);
    justify-content: var(--footer-columns-align, center);
    padding-block: 2rem;
    border-top: 1px solid var(--footer-border, rgb(var(--color-border)));
    border-bottom: 1px solid var(--footer-border, rgb(var(--color-border)));
  }

  .site-footer--no-dividers .site-footer__menus {
    border-top: none;
    border-bottom: none;
  }

  .site-footer__menu-title {
    margin: 0 0 .75rem;
    text-transform: uppercase;
    font-size: var(--font-size-small);
    font-weight: var(--font-body-weight-demibold);
    color: var(--footer-heading, inherit);
  }

  .linklist--footer li {
    margin-bottom: .5rem;
  }

  .linklist--footer a {
    font-size: var(--font-size-small);
    text-transform: lowercase;
    color: var(--footer-link, inherit);
  }

  .linklist--footer a:hover {
    color: var(--footer-link-hover, var(--footer-link, inherit));
  }

  .site-footer__social-icons {
    display: flex;
    justify-content: var(--footer-columns-align, center);
    gap: 1rem;
    padding-top: 1.5rem;
  }

  .social-icon a {
    display: inline-flex;
    color: var(--footer-icon-color, var(--footer-text, rgb(var(--color-text))));
  }

  .site-footer__copyright {
    text-align: center;
    margin-top: 1.5rem;
    font-size: var(--footer-copyright-size, var(--font-size-caption));
    color: var(--footer-text, rgba(var(--color-text), .7));
  }

  @media screen and (max-width: 44.99em) {
    .site-footer__newsletter-form {
      flex-direction: column;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.footer.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.footer.newsletter_header"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "default": true,
      "label": "t:sections.footer.show_newsletter.label"
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "default": "Join the club",
      "label": "t:sections.footer.newsletter_title.label"
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "label": "t:sections.footer.newsletter_subtext.label"
    },
    {
      "type": "text",
      "id": "newsletter_button_text",
      "default": "Sign up",
      "label": "t:sections.footer.newsletter_button_text.label"
    },
    {
      "type": "select",
      "id": "newsletter_button_style",
      "options": [
        { "value": "primary", "label": "t:sections.common.button_style.primary" },
        { "value": "secondary", "label": "t:sections.common.button_style.secondary" }
      ],
      "default": "primary",
      "label": "t:sections.common.button_style.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.colors_header"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.footer.background_color.label",
      "info": "t:sections.footer.background_color.info"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.footer.text_color.label"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "t:sections.footer.heading_color.label"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "t:sections.footer.link_color.label"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "t:sections.footer.link_hover_color.label"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "t:sections.footer.border_color.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.layout_header"
    },
    {
      "type": "select",
      "id": "columns_alignment",
      "options": [
        { "value": "flex-start", "label": "t:sections.common.align.left" },
        { "value": "center", "label": "t:sections.common.align.center" },
        { "value": "flex-end", "label": "t:sections.common.align.right" }
      ],
      "default": "center",
      "label": "t:sections.footer.columns_alignment.label"
    },
    {
      "type": "checkbox",
      "id": "show_dividers",
      "default": true,
      "label": "t:sections.footer.show_dividers.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.social_header"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18,
      "label": "t:sections.footer.icon_size.label"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "t:sections.footer.icon_color.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.copyright_header"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "t:sections.footer.copyright_text.label",
      "info": "t:sections.footer.copyright_text.info"
    },
    {
      "type": "range",
      "id": "copyright_font_size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 10,
      "label": "t:sections.footer.copyright_font_size.label"
    },
    {
      "type": "select",
      "id": "font_override",
      "options": [
        { "value": "inherit", "label": "t:sections.common.font.inherit" },
        { "value": "heading", "label": "t:sections.common.font.heading" },
        { "value": "body", "label": "t:sections.common.font.body" },
        { "value": "accent", "label": "t:sections.common.font.accent" }
      ],
      "default": "inherit",
      "label": "t:sections.common.font.label"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.footer.blocks.link_list.title.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.menu.label"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "t:sections.footer.name",
      "blocks": [{ "type": "link_list" }]
    }
  ]
}
{% endschema %}
