{% comment %}
  Maps to: source site's "cosmic_universe" section — real heading "THE COSMIC
  UNIVERSE", a cross-sell carousel of the whole fragrance family (3 real cards:
  Cosmic Kylie Jenner, Cosmic Kylie Jenner 2.0, Cosmic Kylie Jenner Intense), each
  with a fragrance family, a short "about the scent" line, and key notes.
{% endcomment %}
<div
  id="shopify-section-{{ section.id }}"
  class="cosmic-universe{% if section.settings.font_override != 'inherit' %} cosmic-universe--font-{{ section.settings.font_override }}{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="cosmic-universe"
  style="
    {%- if section.settings.background_type == 'gradient' -%}
    --cosmic-universe-bg: linear-gradient({{ section.settings.gradient_angle }}deg, {{ section.settings.gradient_color_from }}, {{ section.settings.gradient_color_to }});
    {%- else -%}
    --cosmic-universe-bg: {{ section.settings.background_color }};
    {%- endif -%}
    --cosmic-universe-padding-top: {{ section.settings.section_padding_top }}px;
    --cosmic-universe-padding-bottom: {{ section.settings.section_padding_bottom }}px;
    --cosmic-universe-title-color: {{ section.settings.title_color }};
    --cosmic-universe-title-size: {{ section.settings.title_font_size }}px;
    --cosmic-universe-card-gap: {{ section.settings.card_gap }}px;
    --cosmic-universe-image-radius: {{ section.settings.card_image_radius }}px;
    --cosmic-universe-card-title-color: {{ section.settings.card_title_color }};
    --cosmic-universe-card-title-size: {{ section.settings.card_title_font_size }}px;
    --cosmic-universe-card-family-color: {{ section.settings.card_family_color }};
    --cosmic-universe-card-family-size: {{ section.settings.card_family_font_size }}px;
    --cosmic-universe-card-about-color: {{ section.settings.card_about_color }};
    --cosmic-universe-card-about-size: {{ section.settings.card_about_font_size }}px;
    --cosmic-universe-card-notes-color: {{ section.settings.card_notes_color }};
    --cosmic-universe-card-notes-size: {{ section.settings.card_notes_font_size }}px;
  "
>
  {%- if section.settings.title != blank -%}
    <h2 class="cosmic-universe__title page-width">{{ section.settings.title }}</h2>
  {%- endif -%}

  <product-carousel class="cosmic-universe__carousel page-width">
    <div class="carousel__track" data-carousel-track>
      {%- for block in section.blocks -%}
        <div class="cosmic-universe__card" data-carousel-slide {{ block.shopify_attributes }}>
          <a href="{{ block.settings.product.url | default: '#' }}">
            <div class="cosmic-universe__image aspect-ratio" style="--aspect-ratio: {{ section.settings.image_aspect_ratio }};">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 500 | image_tag: widths: '250,375,500', alt: block.settings.title, loading: 'lazy' }}
              {%- endif -%}
            </div>
            <p class="cosmic-universe__card-title">{{ block.settings.title }}</p>
            <p class="cosmic-universe__card-family">{{ block.settings.fragrance_family }}</p>
            <p class="cosmic-universe__card-about">{{ block.settings.about_the_scent }}</p>
            {%- if block.settings.key_notes != blank -%}
              <p class="cosmic-universe__card-notes">{{ block.settings.key_notes }}</p>
            {%- endif -%}
          </a>
        </div>
      {%- endfor -%}
    </div>
  </product-carousel>
</div>

{% stylesheet %}
  .cosmic-universe {
    padding-top: var(--cosmic-universe-padding-top, var(--section-spacing));
    padding-bottom: var(--cosmic-universe-padding-bottom, var(--section-spacing));
    background: var(--cosmic-universe-bg, rgb(var(--color-background-alt)));
  }

  .cosmic-universe__title {
    text-align: center;
    text-transform: uppercase;
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: var(--cosmic-universe-title-size, var(--font-size-h2));
    color: var(--cosmic-universe-title-color, inherit);
    margin-bottom: 1.5rem;
  }

  .cosmic-universe__carousel {
    position: relative;
  }

  .cosmic-universe__carousel .carousel__track {
    display: flex;
    gap: var(--cosmic-universe-card-gap, 1rem);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    justify-content: center;
  }

  .cosmic-universe__card {
    display: flex;
    flex: 0 0 80%;
    flex-direction: column;
    scroll-snap-align: center;
    text-align: center;
    color: rgb(var(--color-text));
  }

  .cosmic-universe__card > a {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .cosmic-universe__image {
    border-radius: var(--cosmic-universe-image-radius, 0px);
    background: rgb(var(--color-background-alt));
  }

  .cosmic-universe__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cosmic-universe__card-title {
    font-weight: var(--font-body-weight-demibold);
    font-size: var(--cosmic-universe-card-title-size, var(--font-size-body));
    color: var(--cosmic-universe-card-title-color, inherit);
    margin-top: .75rem;
    text-transform: lowercase;
  }

  .cosmic-universe__card-family {
    font-size: var(--cosmic-universe-card-family-size, var(--font-size-caption));
    color: var(--cosmic-universe-card-family-color, rgba(var(--color-text), .7));
    text-transform: uppercase;
    letter-spacing: .05em;
  }

  .cosmic-universe__card-about {
    font-size: var(--cosmic-universe-card-about-size, var(--font-size-small));
    color: var(--cosmic-universe-card-about-color, inherit);
    margin-top: .25rem;
  }

  .cosmic-universe__card-notes {
    font-size: var(--cosmic-universe-card-notes-size, var(--font-size-small));
    color: var(--cosmic-universe-card-notes-color, inherit);
    margin-top: .25rem;
  }

  @media screen and (min-width: 45em) {
    .cosmic-universe__card {
      flex-basis: 30%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.cosmic-universe.name",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "THE COSMIC UNIVERSE",
      "label": "t:sections.cosmic-universe.title.label"
    },
    {
      "type": "header",
      "content": "t:sections.cosmic-universe.section_style_header"
    },
    {
      "type": "select",
      "id": "background_type",
      "options": [
        { "value": "solid", "label": "t:sections.cosmic-universe.background_type.solid" },
        { "value": "gradient", "label": "t:sections.cosmic-universe.background_type.gradient" }
      ],
      "default": "solid",
      "label": "t:sections.cosmic-universe.background_type.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "default": "#F8F1F4",
      "label": "t:sections.cosmic-universe.background_color.label",
      "info": "t:sections.cosmic-universe.background_color.info"
    },
    {
      "type": "color",
      "id": "gradient_color_from",
      "default": "#C53627",
      "label": "t:sections.cosmic-universe.gradient_color_from.label"
    },
    {
      "type": "color",
      "id": "gradient_color_to",
      "default": "#F8EDEB",
      "label": "t:sections.cosmic-universe.gradient_color_to.label"
    },
    {
      "type": "range",
      "id": "gradient_angle",
      "min": 0,
      "max": 360,
      "step": 5,
      "unit": "°",
      "default": 180,
      "label": "t:sections.cosmic-universe.gradient_angle.label",
      "info": "t:sections.cosmic-universe.gradient_angle.info"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 48,
      "label": "t:sections.cosmic-universe.section_padding_top.label"
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 48,
      "label": "t:sections.cosmic-universe.section_padding_bottom.label"
    },
    {
      "type": "header",
      "content": "t:sections.cosmic-universe.title_style_header"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "t:sections.cosmic-universe.title_color.label"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 20,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 28,
      "label": "t:sections.cosmic-universe.title_font_size.label"
    },
    {
      "type": "header",
      "content": "t:sections.cosmic-universe.card_style_header"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "options": [
        { "value": "75%", "label": "t:sections.cosmic-universe.image_aspect_ratio.landscape" },
        { "value": "100%", "label": "t:sections.cosmic-universe.image_aspect_ratio.square" },
        { "value": "125%", "label": "t:sections.cosmic-universe.image_aspect_ratio.portrait" },
        { "value": "150%", "label": "t:sections.cosmic-universe.image_aspect_ratio.tall" }
      ],
      "default": "100%",
      "label": "t:sections.cosmic-universe.image_aspect_ratio.label",
      "info": "t:sections.cosmic-universe.image_aspect_ratio.info"
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 16,
      "label": "t:sections.cosmic-universe.card_gap.label"
    },
    {
      "type": "range",
      "id": "card_image_radius",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 0,
      "label": "t:sections.cosmic-universe.card_image_radius.label"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "t:sections.cosmic-universe.card_title_color.label"
    },
    {
      "type": "range",
      "id": "card_title_font_size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 17,
      "label": "t:sections.cosmic-universe.card_title_font_size.label"
    },
    {
      "type": "color",
      "id": "card_family_color",
      "label": "t:sections.cosmic-universe.card_family_color.label"
    },
    {
      "type": "range",
      "id": "card_family_font_size",
      "min": 8,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 10,
      "label": "t:sections.cosmic-universe.card_family_font_size.label"
    },
    {
      "type": "color",
      "id": "card_about_color",
      "label": "t:sections.cosmic-universe.card_about_color.label"
    },
    {
      "type": "range",
      "id": "card_about_font_size",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 15,
      "label": "t:sections.cosmic-universe.card_about_font_size.label"
    },
    {
      "type": "color",
      "id": "card_notes_color",
      "label": "t:sections.cosmic-universe.card_notes_color.label"
    },
    {
      "type": "range",
      "id": "card_notes_font_size",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 15,
      "label": "t:sections.cosmic-universe.card_notes_font_size.label"
    },
    {
      "type": "select",
      "id": "font_override",
      "options": [
        { "value": "inherit", "label": "t:sections.common.font.inherit" },
        { "value": "heading", "label": "t:sections.common.font.heading" },
        { "value": "body", "label": "t:sections.common.font.body" },
        { "value": "accent", "label": "t:sections.common.font.accent" }
      ],
      "default": "inherit",
      "label": "t:sections.common.font.label"
    }
  ],
  "blocks": [
    {
      "type": "fragrance_card",
      "name": "t:sections.cosmic-universe.blocks.fragrance_card.name",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "t:sections.cosmic-universe.blocks.fragrance_card.product.label"
        },
        {
          "type": "image_picker",
