{% comment %}
  Maps to: source site's 7 "hero" instances (Mood Stones, Kylie's Summer Faves,
  The Scent of the Summer, Virtual Try-On, etc). The source implements each
  desktop/mobile pair as TWO separate sections toggled by a >=960px media query;
  rebuilt here as ONE section with desktop_image/mobile_image + optional separate
  mobile button text, per the build brief's explicit desktop/mobile control
  requirement — same visual result, one editable instance instead of two.
{% endcomment %}
<div
  id="shopify-section-{{ section.id }}"
  class="hero{% if section.settings.font_override != 'inherit' %} hero--font-{{ section.settings.font_override }}{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="hero"
  style="--hero-height-mobile: {{ section.settings.height_mobile }}vh; --hero-height-desktop: {{ section.settings.height_desktop }}vh;"
>
  <a
    href="{{ section.settings.link | default: '#' }}"
    class="hero__media-link{% if section.settings.link == blank %} hero__media-link--static{% endif %}"
    {% if section.settings.link == blank %}tabindex="-1" aria-hidden="true"{% endif %}
  >
    <div class="hero__media">
      {%- if section.settings.desktop_video != blank -%}
        {{ section.settings.desktop_video | video_tag: image_size: '1728x', autoplay: true, loop: true, muted: true, controls: false, class: 'hero__video hero__video--desktop' }}
      {%- elsif section.settings.desktop_image != blank -%}
        {{ section.settings.desktop_image | image_url: width: 1728 | image_tag: widths: '750,1100,1500,1728', class: 'hero__image hero__image--desktop', alt: section.settings.heading | default: '', loading: 'lazy' }}
      {%- endif -%}

      {%- comment -%}
        Fall back to the desktop media (still rendered with the --mobile class
        so the responsive breakpoint CSS applies) when no dedicated mobile
        video/image is set, so the hero background is never blank on mobile.
      {%- endcomment -%}
      {%- if section.settings.mobile_video != blank -%}
        {{ section.settings.mobile_video | video_tag: image_size: '750x', autoplay: true, loop: true, muted: true, controls: false, class: 'hero__video hero__video--mobile' }}
      {%- elsif section.settings.mobile_image != blank -%}
        {{ section.settings.mobile_image | image_url: width: 750 | image_tag: widths: '390,540,750', class: 'hero__image hero__image--mobile', alt: section.settings.heading | default: '', loading: 'lazy' }}
      {%- elsif section.settings.desktop_video != blank -%}
        {{ section.settings.desktop_video | video_tag: image_size: '750x', autoplay: true, loop: true, muted: true, controls: false, class: 'hero__video hero__video--mobile' }}
      {%- elsif section.settings.desktop_image != blank -%}
        {{ section.settings.desktop_image | image_url: width: 750 | image_tag: widths: '390,540,750', class: 'hero__image hero__image--mobile', alt: section.settings.heading | default: '', loading: 'lazy' }}
      {%- endif -%}

      {%- if section.settings.overlay_opacity > 0 -%}
        <div class="hero__overlay" style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
      {%- endif -%}
    </div>
  </a>

  <div
    class="hero__content hero__content--h-{{ section.settings.text_align_h }} hero__content--v-{{ section.settings.text_align_v }} hero__content--mobile-{{ section.settings.mobile_layout }}"
    style="--hero-heading-color: {{ section.settings.heading_color }}; --hero-text-color: {{ section.settings.text_color }};"
  >
    {%- if section.settings.eyebrow != blank -%}
      <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="hero__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <div class="hero__subtext">{{ section.settings.subtext }}</div>
    {%- endif -%}

    {%- if section.settings.button_text != blank -%}
      <div class="hero__buttons">
        <a href="{{ section.settings.link }}" class="action action--{{ section.settings.button_style }} hero__button hero__button--desktop">
          {{ section.settings.button_text }}
        </a>
        <a href="{{ section.settings.link }}" class="action action--{{ section.settings.button_style }} hero__button hero__button--mobile">
          {{ section.settings.mobile_button_text | default: section.settings.button_text }}
        </a>
      </div>
    {%- endif -%}

    {%- if section.settings.button2_text != blank -%}
      <a href="{{ section.settings.link2 }}" class="action action--{{ section.settings.button2_style }} hero__button">
        {{ section.settings.button2_text }}
      </a>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .hero {
    position: relative;
    overflow: hidden;
    background-color: rgb(var(--color-background-alt));
    /* Subtract the announcement bar's real height (measured live by
       header.liquid's JS and exposed on :root) so a hero set close to
       100vh doesn't add its own height ON TOP of the announcement bar and
       push the total page height past one full viewport - which is what
       was creating the extra vertical scroll. */
    min-height: calc(var(--hero-height-mobile, 75vh) - var(--announcement-bar-height, 0px));
  }

  @media screen and (min-width: 60em) {
    .hero {
      min-height: calc(var(--hero-height-desktop, 65vh) - var(--announcement-bar-height, 0px));
    }
  }

  .hero__media-link {
    position: absolute;
    inset: 0;
    display: block;
  }

  .hero__media-link--static {
    pointer-events: none;
  }

  .hero__media {
    position: absolute;
    inset: 0;
  }

  .hero__image,
  .hero__video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  /* Belt-and-suspenders: force-hide native controls/UI regardless of how the
     video source renders them, so it always reads as an ambient background
     rather than an embedded player. */
  .hero__video::-webkit-media-controls,
  .hero__video::-webkit-media-controls-panel,
  .hero__video::-webkit-media-controls-play-button,
  .hero__video::-webkit-media-controls-start-playback-button {
    display: none !important;
    -webkit-appearance: none;
  }

  .hero__image--mobile,
  .hero__video--mobile {
    display: none;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: .5rem;
    max-width: 32rem;
    min-height: inherit;
    padding: 3rem var(--container-padding);
    color: rgb(var(--hero-text-color, var(--color-text)));
  }

  .hero__content--h-left { align-items: flex-start; text-align: left; margin-inline-end: auto; }
  .hero__content--h-center { align-items: center; text-align: center; margin-inline: auto; }
  .hero__content--h-right { align-items: flex-end; text-align: right; margin-inline-start: auto; }

  .hero__content--v-top { justify-content: flex-start; }
  .hero__content--v-center { justify-content: center; }
  .hero__content--v-bottom { justify-content: flex-end; }

  .hero__eyebrow {
    font-size: var(--font-size-small);
    text-transform: uppercase;
    letter-spacing: .05em;
  }

  .hero__heading {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    color: rgb(var(--hero-heading-color, var(--color-heading)));
    text-transform: uppercase;
    white-space: pre-line;
  }

  .hero__buttons {
    display: flex;
    gap: .75rem;
  }

  .hero__button--mobile {
    display: none;
  }

  @media screen and (max-width: 59.99em) {
    .hero__image--desktop,
    .hero__video--desktop {
      display: none;
    }
    .hero__image--mobile,
    .hero__video--mobile {
      display: block;
    }
    .hero__content {
      max-width: 100%;
    }
    .hero__content--mobile-over-image {
      position: absolute;
      inset: 0;
    }
    .hero__content--mobile-h-center {
      align-items: center;
      text-align: center;
      margin-inline: auto;
    }
    .hero__button--desktop {
      display: none;
    }
    .hero__button--mobile {
      display: inline-flex;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.hero.name",
  "settings": [
    {
      "type": "range",
      "id": "height_desktop",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 65,
      "label": "t:sections.hero.height_desktop.label"
    },
    {
      "type": "range",
      "id": "height_mobile",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 75,
      "label": "t:sections.hero.height_mobile.label"
    },
    {
      "type": "header",
      "content": "t:sections.hero.desktop_media_header"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "t:sections.hero.desktop_image.label"
    },
    {
      "type": "video",
      "id": "desktop_video",
      "label": "t:sections.hero.desktop_video.label"
    },
    {
      "type": "header",
      "content": "t:sections.hero.mobile_media_header"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "t:sections.hero.mobile_image.label"
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "t:sections.hero.mobile_video.label"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "options": [
        { "value": "below-image", "label": "t:sections.hero.mobile_layout.below_image" },
        { "value": "over-image", "label": "t:sections.hero.mobile_layout.over_image" }
      ],
      "default": "below-image",
      "label": "t:sections.hero.mobile_layout.label"
    },
    {
      "type": "header",
      "content": "t:sections.hero.overlay_header"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "default": "#000000",
      "label": "t:sections.hero.overlay_color.label"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 0,
      "label": "t:sections.hero.overlay_opacity.label"
    },
    {
      "type": "header",
      "content": "t:sections.hero.content_header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.hero.eyebrow.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.hero.heading.label"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "t:sections.hero.subtext.label"
    },
    {
      "type": "color",
      "id": "heading_color",
      "default": "#393939",
      "label": "t:sections.hero.heading_color.label"
    },
    {
      "type": "color",
      "id": "text_color",
      "default": "#393939",
      "label": "t:sections.hero.text_color.label"
    },
    {
      "type": "select",
      "id": "text_align_h",
      "options": [
        { "value": "left", "label": "t:sections.common.align.left" },
        { "value": "center", "label": "t:sections.common.align.center" },
        { "value": "right", "label": "t:sections.common.align.right" }
      ],
      "default": "left",
      "label": "t:sections.hero.text_align_h.label"
    },
    {
      "type": "select",
      "id": "text_align_v",
      "options": [
        { "value": "top", "label": "t:sections.common.align.top" },
        { "value": "center", "label": "t:sections.common.align.center" },
        { "value": "bottom", "label": "t:sections.common.align.bottom" }
      ],
      "default": "center",
      "label": "t:sections.hero.text_align_v.label"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:sections.hero.link.label",
      "info": "t:sections.hero.link.info"
    },
    {
      "type": "header",
      "content": "t:sections.hero.buttons_header"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:sections.hero.button_text.label"
    },
    {
      "type": "text",
      "id": "mobile_button_text",
      "label": "t:sections.hero.mobile_button_text.label",
      "info": "t:sections.hero.mobile_button_text.info"
    },
    {
      "type": "select",
      "id": "button_style",
      "options": [
        { "value": "primary", "label": "t:sections.common.button_style.primary" },
        { "value": "secondary", "label": "t:sections.common.button_style.secondary" }
      ],
      "default": "primary",
      "label": "t:sections.common.button_style.label"
    },
    {
      "type": "text",
      "id": "button2_text",
      "label": "t:sections.hero.button2_text.label"
    },
    {
      "type": "url",
      "id": "link2",
      "label": "t:sections.hero.link2.label"
    },
    {
      "type": "select",
      "id": "button2_style",
      "options": [
        { "value": "primary", "label": "t:sections.common.button_style.primary" },
        { "value": "secondary", "label": "t:sections.common.button_style.secondary" }
      ],
      "default": "secondary",
      "label": "t:sections.common.button_style.label"
    },
    {
      "type": "select",
      "id": "font_override",
      "options": [
        { "value": "inherit", "label": "t:sections.common.font.inherit" },
        { "value": "heading", "label": "t:sections.common.font.heading" },
        { "value": "body", "label": "t:sections.common.font.body" },
        { "value": "accent", "label": "t:sections.common.font.accent" }
      ],
      "default": "inherit",
      "label": "t:sections.common.font.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.hero.name",
      "settings": {
        "heading": "coming july 30 \nmood stones",
        "subtext": "<p>the new fragrance trio from kylie jenner.</p>",
        "button_text": "get notified",
        "heading_color": "#b3848f",
        "text_align_h": "left"
      }
    }
  ]
}
{% endschema %}
